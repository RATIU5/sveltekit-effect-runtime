{
  "name": "sveltekit-effect-bridge",
  "version": "0.0.1",
  "description": "SvelteKit Effect Bridge - write Effect code directly within SvleteKit",
  "keywords": [
    "effect",
    "effect-ts",
    "svelte",
    "sveltekit",
    "vite-plugin"
  ],
  "license": "MIT",
  "contributors": [
    {
      "name": "RATIU5",
      "url": "https://github.com/RATIU5"
    }
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint:check": "oxlint",
    "lint": "oxlint --fix",
    "fmt:check": "oxfmt --check",
    "fmt": "oxfmt",
    "test": "vitest run",
    "prepublishOnly": "pnpm test && pnpm build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@changesets/config": "^3.1.3",
    "@types/bun": "latest",
    "@types/estree": "^1.0.8",
    "@types/node": "^25.5.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.55.0",
    "effect": "^4.0.0-beta.43",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
